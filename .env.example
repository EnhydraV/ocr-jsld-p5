# Environment
# NODE_ENV n'est volontairement PAS défini ici : Next le pose lui-même
# (development pour `next dev`, production pour `next build`/`next start`).
# Le forcer casse le build de prod (React resterait en mode dev). Cf. NOTES.md.
PORT=3000

# Database connection string
DATABASE_USER='mdd'
DATABASE_PASSWORD='mddpass'
DATABASE_PORT='5432'
DATABASE_NAME='mdd'
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@localhost:${DATABASE_PORT}/${DATABASE_NAME}?schema=public"

# Configuration NextAuth v4
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"